{
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-native",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "lib": [
      "ESNext",
      "DOM"
    ],
    "types": [
      "node",
      "react",
      "react-native"
    ],
    "noImplicitAny": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "allowJs": true,
    "noUnusedLocals": false,
    "strictNullChecks": false
  },
  "include": [
    "api",
    "app",
    "lib",
    "components",
    "hooks",
    "constants",
    "context",
    "store",
    "types",
    "utils",
    "pages",
    "App.js",
    "App.tsx"
  ],
  "extends": "expo/tsconfig.base.json"
}