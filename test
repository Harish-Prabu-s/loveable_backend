/**
 * Bug Condition Exploration Test for React Native/Expo Dependency Incompatibilities
 * 
 * **Validates: Requirements 1.1, 1.2, 1.3, 1.4**
 * 
 * This test encodes the EXPECTED behavior - the app should launch successfully
 * with compatible dependency versions.
 * 
 * CRITICAL: This test MUST FAIL on unfixed code (current incompatible versions)
 * - Failure confirms the bug exists
 * - Success after fix confirms the bug is resolved
 * 
 * Current (UNFIXED) versions that should cause failure:
 * - React Native 0.81.5 (incompatible with Expo SDK 54)
 * - Expo SDK ~54.0.32 (requires React Native 0.76.x)
 * - React 19.1.0 (incompatible with React Native 0.81.5)
 * - expo-router ~6.0.23 (requires React Native 0.76.x+)
 */

import { describe, it, expect } from 'vitest';
import { readFileSync } from 'fs';
import { join } from 'path';

describe('Bug Condition Exploration: App Build and Launch with Dependency Versions', () => {
  /**
   * Property 1: Fault Condition - App Crashes with Incompatible Dependency Versions
   * 
   * This property tests that the app launches successfully with compatible versions.
   * On UNFIXED code with incompatible versions, this test MUST FAIL.
   * 
   * The test verifies:
   * 1. React Native version is compatible with Expo SDK 54 (requires 0.76.x+)
   * 2. React version is compatible with React Native (requires 18.x for RN 0.81.5)
   * 3. expo-router version is compatible with React Native (requires 0.76.x+)
   * 4. All peer dependencies are satisfied
   */
  it('should have compatible dependency versions for Android app launch', () => {
    // Read package.json to check current dependency versions
    const packageJsonPath = join(process.cwd(), 'package.json');
    const packageJson = JSON.parse(readFileSync(packageJsonPath, 'utf-8'));
    
    const reactNativeVersion = packageJson.dependencies['react-native'];
    const expoVersion = packageJson.dependencies['expo'];
    const reactVersion = packageJson.dependencies['react'];
    const expoRouterVersion = packageJson.dependencies['expo-router'];
    
    // Extract major.minor version numbers for comparison
    const extractVersion = (versionString: string): { major: number; minor: number } => {
      const cleaned = versionString.replace(/^[\^~]/, '');
      const parts = cleaned.split('.');
      return {
        major: parseInt(parts[0], 10),
        minor: parseInt(parts[1], 10)
      };
    };
    
    const rnVersion = extractVersion(reactNativeVersion);
    const reactVer = extractVersion(reactVersion);
    const expoVer = extractVersion(expoVersion);
    const routerVer = extractVersion(expoRouterVersion);
    
    // ASSERTION 1: React Native version must be 0.76.x or higher for Expo SDK 54
    // Current UNFIXED code has 0.81.5 which appears newer but is actually older
    // This will FAIL on unfixed code because 0.81.5 is incompatible
    const isReactNativeCompatibleWithExpo = 
      (rnVersion.major === 0 && rnVersion.minor >= 76) || rnVersion.major > 0;
    
    expect(isReactNativeCompatibleWithExpo).toBe(true);
    expect(rnVersion.major).toBe(0);
    expect(rnVersion.minor).toBeGreaterThanOrEqual(76);
    
    // ASSERTION 2: React version must be 18.x for React Native 0.76.x
    // Current UNFIXED code has React 19.1.0 which is incompatible
    // This will FAIL on unfixed code
    const isReactCompatibleWithReactNative = reactVer.major === 18;
    
    expect(isReactCompatibleWithReactNative).toBe(true);
    expect(reactVer.major).toBe(18);
    
    // ASSERTION 3: expo-router 6.x requires React Native 0.76.x+
    // Current UNFIXED code has React Native 0.81.5 which doesn't meet this requirement
    // This will FAIL on unfixed code
    if (routerVer.major >= 6) {
      expect(rnVersion.minor).toBeGreaterThanOrEqual(76);
    }
    
    // ASSERTION 4: Expo SDK 54 requires React Native 0.76.x
    // Current UNFIXED code has React Native 0.81.5 which is incompatible
    // This will FAIL on unfixed code
    if (expoVer.major === 54 || (expoVer.major === 0 && expoVer.minor === 54)) {
      expect(rnVersion.minor).toBeGreaterThanOrEqual(76);
    }
    
    // Document the versions being tested
    console.log('Testing with dependency versions:');
    console.log(`  React Native: ${reactNativeVersion}`);
    console.log(`  Expo SDK: ${expoVersion}`);
    console.log(`  React: ${reactVersion}`);
    console.log(`  expo-router: ${expoRouterVersion}`);
    console.log('');
    console.log('Compatibility checks:');
    console.log(`  React Native compatible with Expo SDK 54: ${isReactNativeCompatibleWithExpo}`);
    console.log(`  React compatible with React Native: ${isReactCompatibleWithReactNative}`);
    console.log(`  React Native version (0.${rnVersion.minor}.x) >= 0.76.x: ${rnVersion.minor >= 76}`);
  });
  
  /**
   * Additional verification: Check for peer dependency conflicts
   * This test documents the specific peer dependency issues
   */
  it('should not have peer dependency conflicts', () => {
    const packageJsonPath = join(process.cwd(), 'package.json');
    const packageJson = JSON.parse(readFileSync(packageJsonPath, 'utf-8'));
    
    const reactNativeVersion = packageJson.dependencies['react-native'];
    const reactVersion = packageJson.dependencies['react'];
    
    const rnVersion = extractVersion(reactNativeVersion);
    const reactVer = extractVersion(reactVersion);
    
    // React Native 0.81.5 only supports React 18.x
    // React 19.x requires React Native 0.76.5+
    // This will FAIL on unfixed code with React 19.1.0
    
    // CRITICAL: React Native 0.81.x is OLDER than 0.76.x (versioning anomaly)
    // So if we have RN 0.81.x, it's incompatible with React 19
    const isRNVersionOld = rnVersion.minor === 81;
    
    if (isRNVersionOld || (rnVersion.major === 0 && rnVersion.minor < 76)) {
      expect(reactVer.major).toBeLessThan(19);
    }
    
    // Document the conflict
    console.log('Peer dependency check:');
    console.log(`  React Native version: 0.${rnVersion.minor}.x`);
    console.log(`  React version: ${reactVer.major}.x`);
    console.log(`  Is RN 0.81.x (old version): ${isRNVersionOld}`);
    console.log(`  Compatible: ${reactVer.major < 19 || (!isRNVersionOld && rnVersion.minor >= 76)}`);
  });
});

// Helper function for version extraction (defined outside describe block for reuse)
function extractVersion(versionString: string): { major: number; minor: number } {
  const cleaned = versionString.replace(/^[\^~]/, '');
  const parts = cleaned.split('.');
  return {
    major: parseInt(parts[0], 10),
    minor: parseInt(parts[1], 10)
  };
}

