# SFU Server Environment Variables
# Copy this file to .env and fill in your values

# ── Network ───────────────────────────────────────────────────────────────────
# Port the SFU server listens on
SFU_PORT=3000

# CRITICAL: Your server's public IP address (not 0.0.0.0, not localhost)
# mediasoup uses this in ICE candidates sent to clients
# Without this, peers OUTSIDE the same LAN cannot connect
ANNOUNCED_IP=72.62.195.63

# Mediasoup RTP port range (open these on your firewall/security group)
RTC_MIN_PORT=40000
RTC_MAX_PORT=49999

# ── Authentication ────────────────────────────────────────────────────────────
# Must match DJANGO_SECRET_KEY from your Django backend .env
# This is used to verify JWT tokens issued by Django SimpleJWT
DJANGO_SECRET_KEY=trsxfaepmezlu#z)fq&&zeup-dzlu-5w1j)vfofsb%yewi8!cb

# ── Room limits ───────────────────────────────────────────────────────────────
# Maximum video participants per room
# Increase if your server has more CPU cores / RAM
# Rule of thumb: 1 mediasoup worker = ~25 video streams
MAX_PARTICIPANTS=25

# ── Logging ───────────────────────────────────────────────────────────────────
# Mediasoup log level: debug | warn | error | none
MEDIASOUP_LOG_LEVEL=warn
